# מפתחות API של חשבונית ירוקה (morning)
# ניתן להזין את המפתחות ישירות מדף ⚙️ Settings באפליקציה — אין צורך לערוך קובץ זה ידנית.
# הערכים נשמרים כאן מקומית בלבד ולא נשלחים ל-git.

# --- סביבת בדיקות (Sandbox) ---
GI_SANDBOX_API_KEY=
GI_SANDBOX_API_SECRET=

# --- סביבת ייצור (Production) ---
GI_PROD_API_KEY=
GI_PROD_API_SECRET=

# כתובות בסיס (אופציונלי — ברירת המחדל תקינה, אין צורך לשנות)
